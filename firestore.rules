rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /named_json_store/{documentId} {
      allow read: if true;
      allow create, update: if isValidNamedJsonStore();
      allow delete: if true;
    }

    function isValidNamedJsonStore() {
      return request.resource.data.keys().hasOnly([
          "name",
          "content_type",
          "content",
          "updated_at"
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.updated_at is number &&
        (
          (
            request.resource.data.content_type == "json" &&
            request.resource.data.content is map
          ) ||
          (
            request.resource.data.content_type == "list" &&
            request.resource.data.content is list
          )
        );
    }
  }
}
